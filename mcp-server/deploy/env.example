# gh-mcp environment configuration
# Copy to /etc/gh-mcp/env (or any secure location), fill in values, chmod 600.
# The systemd service reads this file via EnvironmentFile=.
#
# These values can also be injected by a secrets manager (gopass, Vault, etc.)
# at service start — the variable names are what matter.

# GitHub personal access token — required only if your corpus repo is private
# Scope needed: repo (read-only)
# Example using gopass: GITHUB_TOKEN=$(gopass show -o github/tokens/llmemos-mcp)
GITHUB_TOKEN=

# Comma-separated repo slugs this server is allowed to access (allowlist)
# Use the GitHub owner/repo format: your-username/your-corpus-repo
# Multiple repos: repo1,repo2
ALLOWED_REPOS=your-username/your-corpus-repo

# Comma-separated GPG key fingerprints trusted for signature verification
# These must match the fingerprints in your corpus AGENTS.md and bootstrap instructions
# Run: gpg --list-secret-keys --keyid-format LONG
TRUSTED_KEYS=AAAA0000111122223333444455556666BBBB7777

# Local directory for cached repo clones (default: /tmp/gh-mcp-cache)
# Use a persistent path if you want the cache to survive server restarts
CACHE_DIR=/var/cache/gh-mcp

# Seconds before a cached repo is re-pulled (default: 300)
CACHE_TTL=300

# Port to listen on (default: 8788)
# Change if another service is using this port
PORT=8788

# Comma-separated public hostnames accepted in the Host header
# Required when running behind a reverse proxy (Cloudflare Tunnel, nginx, etc.)
# Set to the public hostname your tunnel/proxy presents
ALLOWED_HOSTS=llmemos-mcp.your-domain.example.com
